# GitHub Personal Access Token（需 repo 权限，方案一，可选）
# 生成：GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub OAuth App（方案二，可选，用于本地“使用 GitHub 登录”）
# 在 GitHub Developer Settings → OAuth Apps 新建应用：
# - Homepage URL: http://localhost:3846/
# - Authorization callback URL: http://localhost:3846/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=xxxx
GITHUB_OAUTH_CLIENT_SECRET=yyyy

# 服务端口（可选，默认 3846）
PORT=3846
